# frozen_string_literal: true

# ──────────────────────────────────────────────────────────────────────────────
# Fastfile — AOF Foundation App
# Architecture: EAS Build (cloud) + Fastlane (submit + metadata + code signing)
#
# Builds are produced by EAS. Fastlane handles:
#   • Certificate/profile sync via match
#   • TestFlight upload via pilot
#   • App Store submission via deliver
# ──────────────────────────────────────────────────────────────────────────────

default_platform(:ios)

# Load ASC API key (used by pilot and deliver)
def asc_api_key
  app_store_connect_api_key(
    key_id:       ENV.fetch("ASC_KEY_ID",    "6WLF6XCC5H"),
    issuer_id:    ENV.fetch("ASC_ISSUER_ID"),               # required – set in CI or .env
    key_filepath: ENV.fetch("ASC_KEY_PATH",  File.expand_path("~/Downloads/AuthKey_6WLF6XCC5H.p8")),
    duration:     1200,
    in_house:     false
  )
end

platform :ios do

  # ── beta ──────────────────────────────────────────────────────────────────
  desc "Upload an IPA to TestFlight (built externally by EAS)"
  lane :beta do |options|
    ipa_path = options[:ipa] || ENV["IPA_PATH"] || UI.input("Path to .ipa file: ")
    UI.user_error!("IPA not found: #{ipa_path}") unless File.exist?(ipa_path)

    upload_to_testflight(
      api_key:                           asc_api_key,
      ipa:                               ipa_path,
      skip_waiting_for_build_processing: true,
      distribute_external:               false
    )
  end

  # ── release ───────────────────────────────────────────────────────────────
  desc "Submit an IPA to App Store for review (built externally by EAS)"
  lane :release do |options|
    ipa_path = options[:ipa] || ENV["IPA_PATH"] || UI.input("Path to .ipa file: ")
    UI.user_error!("IPA not found: #{ipa_path}") unless File.exist?(ipa_path)

    deliver(
      api_key:                         asc_api_key,
      ipa:                             ipa_path,
      submit_for_review:               true,
      automatic_release:               false,
      force:                           true,
      metadata_path:                   "./fastlane/metadata",
      precheck_include_in_app_purchases: false,
      skip_screenshots:                false,
      run_precheck_before_submit:      true
    )
  end

  # ── sync_certs ────────────────────────────────────────────────────────────
  desc "Sync code signing certificates and provisioning profiles via match"
  lane :sync_certs do |options|
    cert_type = options[:type] || "appstore"
    match(
      type:           cert_type,
      git_url:        "https://github.com/aofnfp/certificates.git",
      app_identifier: CredentialsManager::AppfileConfig.try_fetch_value(:app_identifier),
      readonly:       options[:readonly] || true
    )
  end

  # ── metadata_upload ───────────────────────────────────────────────────────
  desc "Push metadata and screenshots to App Store Connect (no binary)"
  lane :metadata_upload do
    deliver(
      api_key:           asc_api_key,
      skip_binary_upload: true,
      skip_screenshots:   false,
      force:              true,
      metadata_path:      "./fastlane/metadata"
    )
  end

end
